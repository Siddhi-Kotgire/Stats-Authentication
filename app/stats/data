// ── Derivation helpers ────────────────────────────────────────────────────────
function deriveUsers(period) {
  return users.map((u) => {
    const toolVals = period === "hours" ? u.hours : u.days;
    return {
      ...u,
      tools: toolVals,
      total: toolVals.reduce((a, b) => a + b, 0),
    };
  });
}

function deriveTools(period) {
  const derived = deriveUsers(period);
  return tools.map((t, i) => ({
    ...t,
    total: derived.reduce((s, u) => s + u.tools[i], 0),
  }));
}

export function getDataForPeriod(period) {
  const u = deriveUsers(period);
  const t = deriveTools(period);
  const totalVal = u.reduce((s, x) => s + x.total, 0);
  const sorted = [...u].sort((a, b) => b.total - a.total);
  const sortedTools = [...t].sort((a, b) => b.total - a.total);
  return {
    users: u,
    tools: t,
    orgStats: {
      totalUsers: u.length,
      totalVal,
      avgPerUser: Math.round(totalVal / u.length),
      activeUsers: u.filter((x) => x.status === "online").length,
      mostActiveUser: sorted[0],
      mostUsedTool: sortedTools[0],
    },
  };
}

// Default exports for backward compat (hours as default)
const _default = getDataForPeriod("hours");
export const orgStats = _default.orgStats;
